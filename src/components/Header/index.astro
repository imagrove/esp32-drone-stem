---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { defaultLang, ui } from '../../i18n/ui';
import Desktop from './Desktop.astro';
import Mobile from './Mobile.astro';

// Detect language from URL
const pathParts = Astro.url.pathname.split('/').filter(Boolean);
let lang = defaultLang;

if (pathParts[0] === 'tutorials' && pathParts[1] && pathParts[1] in ui) {
  // Tutorial page: /tutorials/zh/...
  lang = pathParts[1] as keyof typeof ui;
} else if (pathParts[0] && pathParts[0] in ui) {
  // Root level: /zh/...
  lang = pathParts[0] as keyof typeof ui;
}

const t = useTranslations(lang);
const isZh = lang === 'zh';

// Get current path for active link highlighting
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '/zh/';
const isTutorials = currentPath.includes('/tutorials');
const isHardware = currentPath.includes('/hardware');
const isDownloads = currentPath.includes('/downloads');

const navProps = {
  lang,
  isZh,
  isHome,
  isTutorials,
  isHardware,
  isDownloads
};
---

<header class="site-header">
  <nav class="header-nav">
    <a href={isZh ? "/zh/" : "/"} class="site-logo">ESP32 Drone</a>

    <!-- Desktop Navigation -->
    <Desktop {...navProps} />

    <!-- Mobile Navigation -->
    <Mobile {...navProps} />
  </nav>
</header>

<style>
  .site-header {
    background: white;
    border-bottom: 1px solid var(--border);
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-nav {
    max-width: var(--content-max-width, 1200px);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
  }

  .site-logo {
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--text-dark);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .site-logo:hover {
    color: var(--primary);
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .site-header {
      padding: 0.75rem 1rem;
    }

    .site-logo {
      font-size: 1.1rem;
    }
  }
</style>
