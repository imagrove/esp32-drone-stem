---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import TutorialSidebar from './TutorialSidebar.astro';
import { useTranslations } from '../i18n/utils';
import { defaultLang, ui } from '../i18n/ui';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'tutorials'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Detect language from entry slug (e.g., "zh/beginner/01-first-flight")
const langFromSlug = entry.slug.split('/')[0];
const lang = (langFromSlug && langFromSlug in ui) 
  ? langFromSlug as keyof typeof ui 
  : defaultLang;
const t = useTranslations(lang);
---

<Layout
    title={`${entry.data.title} - ESP32 Drone Tutorial`}
    description={entry.data.description}
    lang={lang}
>
    <Header />

    <div style="display: grid; grid-template-columns: 280px 1fr; min-height: calc(100vh - 70px);">
        <TutorialSidebar />

        <!-- Content -->
        <main style="padding: 2rem; max-width: 800px;">
            <div style="margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border);">
                <span style="font-size: 0.85rem; color: var(--text-light); text-transform: uppercase;">
                    {entry.data.level} Level
                </span>
                <h1 style="margin: 0.5rem 0; font-size: 2rem;">{entry.data.title}</h1>
                <p style="color: var(--text-medium); font-size: 1.1rem;">{entry.data.description}</p>
                <div style="display: flex; gap: 1rem; margin-top: 1rem; font-size: 0.85rem; color: var(--text-light);">
                    <span>⏱️ {entry.data.duration}</span>
                    {entry.data.prerequisites && entry.data.prerequisites.length > 0 && (
                        <span>📋 {entry.data.prerequisites.join(', ')}</span>
                    )}
                </div>
            </div>

            <article class="tutorial-content" style="line-height: 1.8; font-size: 1rem;">
                <Content />
            </article>

            <!-- Navigation -->
            <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border); display: flex; justify-content: space-between;">
                <a href={lang === 'zh' ? '/zh/tutorials' : '/tutorials'} style="color: var(--text-medium);">← {t('nav.tutorials')}</a>
            </div>
        </main>
    </div>
    <Footer />
</Layout>

<style>
    .tutorial-content :global(h2) {
        margin-top: 2rem;
        margin-bottom: 1rem;
        font-size: 1.5rem;
        color: var(--text-dark);
    }
    .tutorial-content :global(h3) {
        margin-top: 1.5rem;
        margin-bottom: 0.75rem;
        font-size: 1.25rem;
        color: var(--text-dark);
    }
    .tutorial-content :global(p) {
        margin-bottom: 1rem;
    }
    .tutorial-content :global(ul), .tutorial-content :global(ol) {
        margin-bottom: 1rem;
        padding-left: 1.5rem;
    }
    .tutorial-content :global(li) {
        margin-bottom: 0.5rem;
    }
    .tutorial-content :global(code) {
        background: var(--bg-light);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.9em;
    }
    .tutorial-content :global(pre) {
        background: #1E293B;
        color: #E2E8F0;
        padding: 1rem;
        border-radius: var(--radius);
        overflow-x: auto;
        margin-bottom: 1rem;
    }
    .tutorial-content :global(pre code) {
        background: transparent;
        padding: 0;
    }
</style>
