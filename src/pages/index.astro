---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header/index.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const isZh = lang === 'zh';
---

<Layout
    title={isZh ? "ESP32 Drone - 开源无人机 STEM 教育平台 | 无人机教育套件" : "ESP32 Drone Kit for STEM Education | Open Source Programmable Drone"}
    description={isZh ? "基于 ESP32 的开源无人机教育平台，支持 Wi-Fi 手机控制。从组装到 AI 编程的完整 STEM 课程体系，适合教育机构和创客使用。" : "Open source ESP32 drone kit for STEM education. Programmable drone with Wi-Fi control, complete tutorials from assembly to AI. Ideal for schools, makers, and drone education programs."}
    lang={lang}
>
    <Header />
    
    <main style="max-width: 1200px; margin: 0 auto; padding: 4rem 2rem;">
        <!-- Hero -->
        <section style="text-align: center; margin-bottom: 4rem;">
            <h1 style="font-size: 2.75rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-dark);">
                {t('home.title').split(' ').slice(0, -3).join(' ')}<br>{t('home.title').split(' ').slice(-3).join(' ')}
            </h1>
            <p style="font-size: 1.2rem; color: var(--text-medium); max-width: 650px; margin: 0 auto 2rem;">
                {t('home.subtitle')}
            </p>
            <div style="display: flex; gap: 1rem; justify-content: center;">
                <a href={isZh ? "/zh/tutorials" : "/tutorials"} style="background: var(--primary); color: white; padding: 0.75rem 1.5rem; border-radius: var(--radius); font-weight: 600;">{t('home.cta.start')}</a>
                <a href={isZh ? "/zh/hardware" : "/hardware"} style="border: 1px solid var(--border); padding: 0.75rem 1.5rem; border-radius: var(--radius); color: var(--text-dark);">{t('home.cta.hardware')}</a>
                <a href={isZh ? "/zh/downloads" : "/downloads"} style="border: 1px solid var(--border); padding: 0.75rem 1.5rem; border-radius: var(--radius); color: var(--text-dark);">{t('home.cta.downloads')}</a>
            </div>
        </section>
        
        <!-- Features -->
        <section style="margin-bottom: 4rem;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;">
                <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; text-align: center;">
                    <div style="font-size: 2.5rem; margin-bottom: 1rem;">📚</div>
                    <h3>{t('feature.curriculum.title')}</h3>
                    <p style="color: var(--text-medium); font-size: 0.9rem;">{t('feature.curriculum.desc')}</p>
                </div>
                <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; text-align: center;">
                    <div style="font-size: 2.5rem; margin-bottom: 1rem;">💻</div>
                    <h3>{t('feature.framework.title')}</h3>
                    <p style="color: var(--text-medium); font-size: 0.9rem;">{t('feature.framework.desc')}</p>
                </div>
                <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; text-align: center;">
                    <div style="font-size: 2.5rem; margin-bottom: 1rem;">📶</div>
                    <h3>{t('feature.wifi.title')}</h3>
                    <p style="color: var(--text-medium); font-size: 0.9rem;">{t('feature.wifi.desc')}</p>
                </div>
                <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; text-align: center;">
                    <div style="font-size: 2.5rem; margin-bottom: 1rem;">🔧</div>
                    <h3>{t('feature.hardware.title')}</h3>
                    <p style="color: var(--text-medium); font-size: 0.9rem;">{t('feature.hardware.desc')}</p>
                </div>
            </div>
        </section>

        <!-- Course Levels -->
        <section style="margin-bottom: 4rem;">
            <h2 style="text-align: center; font-size: 1.75rem; margin-bottom: 0.5rem;">{t('courses.title')}</h2>
            <p style="text-align: center; color: var(--text-medium); margin-bottom: 2rem;">{t('courses.subtitle')}</p>
            
            <div class="course-grid">
                <!-- Beginner -->
                <div class="course-card">
                    <div class="course-header" style="background: #10B981;">
                        <h3>{t('courses.beginner.title')}</h3>
                        <p>{t('courses.beginner.desc')}</p>
                    </div>
                    <div class="course-body">
                        <div class="course-row">
                            <span>{t('courses.level')}</span>
                            <strong>{isZh ? '初级' : 'Beginner'}</strong>
                        </div>
                        <div class="course-row">
                            <span>{t('courses.coding')}</span>
                            <strong>{isZh ? '零基础' : 'No coding'}</strong>
                        </div>
                        <div class="course-row">
                            <span>{t('courses.duration')}</span>
                            <strong>{isZh ? '1-2 周' : '1-2 weeks'}</strong>
                        </div>
                        <div class="course-row last">
                            <span>{t('courses.projects')}</span>
                            <strong>{isZh ? '6 个趣味项目' : '6 fun projects'}</strong>
                        </div>
                        <a href={isZh ? "/tutorials/zh/beginner/01-first-flight" : "/tutorials/en/beginner/01-first-flight"} class="course-btn" style="background: #10B981;">{t('courses.cta')}</a>
                    </div>
                </div>

                <!-- Intermediate -->
                <div class="course-card">
                    <div class="course-header" style="background: var(--primary);">
                        <h3>{t('courses.intermediate.title')}</h3>
                        <p>{t('courses.intermediate.desc')}</p>
                    </div>
                    <div class="course-body">
                        <div class="course-row">
                            <span>{t('courses.level')}</span>
                            <strong>{isZh ? '中级' : 'Intermediate'}</strong>
                        </div>
                        <div class="course-row">
                            <span>{t('courses.coding')}</span>
                            <strong>{isZh ? '基础 C 语言' : 'Basic C'}</strong>
                        </div>
                        <div class="course-row">
                            <span>{t('courses.duration')}</span>
                            <strong>{isZh ? '1-2 个月' : '1-2 months'}</strong>
                        </div>
                        <div class="course-row last">
                            <span>{t('courses.projects')}</span>
                            <strong>{isZh ? '9 个进阶项目' : '9 advanced projects'}</strong>
                        </div>
                        <a href={isZh ? "/tutorials/zh/intermediate/01-customization" : "/tutorials/en/intermediate/01-customization"} class="course-btn" style="background: var(--primary);">{t('courses.cta')}</a>
                    </div>
                </div>

                <!-- Advanced -->
                <div class="course-card">
                    <div class="course-header" style="background: #DC2626;">
                        <h3>{t('courses.advanced.title')}</h3>
                        <p>{t('courses.advanced.desc')}</p>
                    </div>
                    <div class="course-body">
                        <div class="course-row">
                            <span>{t('courses.level')}</span>
                            <strong>{isZh ? '高级' : 'Advanced'}</strong>
                        </div>
                        <div class="course-row">
                            <span>{t('courses.coding')}</span>
                            <strong>{isZh ? 'C 语言 + Python' : 'C + Python'}</strong>
                        </div>
                        <div class="course-row">
                            <span>{t('courses.duration')}</span>
                            <strong>{isZh ? '2-3 个月' : '2-3 months'}</strong>
                        </div>
                        <div class="course-row last">
                            <span>{t('courses.projects')}</span>
                            <strong>{isZh ? '11 个挑战项目' : '11 challenge projects'}</strong>
                        </div>
                        <a href={isZh ? "/tutorials/zh/advanced/01-advanced-control" : "/tutorials/en/advanced/01-advanced-control"} class="course-btn" style="background: #DC2626;">{t('courses.cta')}</a>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>

<style>
    .course-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
        align-items: start;
    }

    .course-card {
        background: white;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        display: grid;
        grid-template-rows: auto 1fr;
    }

    .course-header {
        color: white;
        padding: 1.5rem;
    }

    .course-header h3 {
        margin: 0 0 0.5rem 0;
        font-size: 1.25rem;
        line-height: 1.3;
    }

    .course-header p {
        opacity: 0.9;
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.4;
    }

    .course-body {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
    }

    .course-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.5rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border);
    }

    .course-row span {
        color: var(--text-light);
    }

    .course-row.last {
        margin-bottom: 1rem;
        border-bottom: none;
    }

    .course-btn {
        color: white;
        padding: 0.5rem 1rem;
        border-radius: var(--radius);
        display: block;
        text-align: center;
        text-decoration: none;
        margin-top: auto;
    }

    @media (min-width: 992px) {
        .course-grid {
            grid-template-columns: repeat(3, 1fr);
        }

        .course-card {
            grid-template-rows: subgrid;
            grid-row: span 2;
        }
    }
</style>
