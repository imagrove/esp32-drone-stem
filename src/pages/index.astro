---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const isZh = lang === 'zh';
---

<Layout 
    title={isZh ? "ESP32 Drone - 开源无人机 STEM 教育平台 | 无人机教育套件" : "ESP32 Drone Kit for STEM Education | Open Source Programmable Drone"}
    description={isZh ? "基于 ESP32 的开源无人机教育平台，支持 Wi-Fi 手机控制。从组装到 AI 编程的完整 STEM 课程体系，适合教育机构和创客使用。" : "Open source ESP32 drone kit for STEM education. Programmable drone with Wi-Fi control, complete tutorials from assembly to AI. Ideal for schools, makers, and drone education programs."}
    lang={lang}
>
    <header style="background: white; border-bottom: 1px solid var(--border); padding: 1rem 2rem;">
        <nav style="max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center;">
            <a href={isZh ? "/zh/" : "/"} style="font-weight: 700; font-size: 1.25rem; color: var(--text-dark);">ESP32 Drone</a>
            <div style="display: flex; gap: 2rem;">
                <a href={isZh ? "/zh/" : "/"} style="font-weight: 600;">{t('nav.home')}</a>
                <a href={isZh ? "/zh/tutorials" : "/tutorials"}>{t('nav.tutorials')}</a>
                <a href={isZh ? "/zh/hardware" : "/hardware"}>{t('nav.hardware')}</a>
                <a href={isZh ? "/zh/downloads" : "/downloads"}>{t('nav.downloads')}</a>
            </div>
            <div>
                <a href={isZh ? "/" : "/zh/"}>{t('nav.lang')}</a>
            </div>
        </nav>
    </header>
    
    <main style="max-width: 1200px; margin: 0 auto; padding: 4rem 2rem;">
        <!-- Hero -->
        <section style="text-align: center; margin-bottom: 4rem;">
            <h1 style="font-size: 2.75rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-dark);">
                {t('home.title').split(' ').slice(0, -3).join(' ')}<br>{t('home.title').split(' ').slice(-3).join(' ')}
            </h1>
            <p style="font-size: 1.2rem; color: var(--text-medium); max-width: 650px; margin: 0 auto 2rem;">
                {t('home.subtitle')}
            </p>
            <div style="display: flex; gap: 1rem; justify-content: center;">
                <a href={isZh ? "/zh/tutorials" : "/tutorials"} style="background: var(--primary); color: white; padding: 0.75rem 1.5rem; border-radius: var(--radius); font-weight: 600;">{t('home.cta.start')}</a>
                <a href={isZh ? "/zh/hardware" : "/hardware"} style="border: 1px solid var(--border); padding: 0.75rem 1.5rem; border-radius: var(--radius); color: var(--text-dark);">{t('home.cta.hardware')}</a>
                <a href={isZh ? "/zh/downloads" : "/downloads"} style="border: 1px solid var(--border); padding: 0.75rem 1.5rem; border-radius: var(--radius); color: var(--text-dark);">{t('home.cta.downloads')}</a>
            </div>
        </section>
        
        <!-- Features -->
        <section style="margin-bottom: 4rem;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;">
                <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; text-align: center;">
                    <div style="font-size: 2.5rem; margin-bottom: 1rem;">📚</div>
                    <h3>{t('feature.curriculum.title')}</h3>
                    <p style="color: var(--text-medium); font-size: 0.9rem;">{t('feature.curriculum.desc')}</p>
                </div>
                <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; text-align: center;">
                    <div style="font-size: 2.5rem; margin-bottom: 1rem;">💻</div>
                    <h3>{t('feature.framework.title')}</h3>
                    <p style="color: var(--text-medium); font-size: 0.9rem;">{t('feature.framework.desc')}</p>
                </div>
                <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; text-align: center;">
                    <div style="font-size: 2.5rem; margin-bottom: 1rem;">📶</div>
                    <h3>{t('feature.wifi.title')}</h3>
                    <p style="color: var(--text-medium); font-size: 0.9rem;">{t('feature.wifi.desc')}</p>
                </div>
                <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; text-align: center;">
                    <div style="font-size: 2.5rem; margin-bottom: 1rem;">🔧</div>
                    <h3>{t('feature.hardware.title')}</h3>
                    <p style="color: var(--text-medium); font-size: 0.9rem;">{t('feature.hardware.desc')}</p>
                </div>
            </div>
        </section>

        <!-- Course Levels -->
        <section style="margin-bottom: 4rem;">
            <h2 style="text-align: center; font-size: 1.75rem; margin-bottom: 0.5rem;">{t('courses.title')}</h2>
            <p style="text-align: center; color: var(--text-medium); margin-bottom: 2rem;">{t('courses.subtitle')}</p>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
                <!-- Beginner -->
                <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden;">
                    <div style="background: #10B981; color: white; padding: 1.5rem;">
                        <h3 style="margin-bottom: 0.5rem;">{t('courses.beginner.title')}</h3>
                        <p style="opacity: 0.9;">{t('courses.beginner.desc')}</p>
                    </div>
                    <div style="padding: 1.5rem;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);">
                            <span style="color: var(--text-light);">{t('courses.level')}</span>
                            <strong>{isZh ? '初级' : 'Beginner'}</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);">
                            <span style="color: var(--text-light);">{t('courses.coding')}</span>
                            <strong>{isZh ? '零基础' : 'No coding'}</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);">
                            <span style="color: var(--text-light);">{t('courses.duration')}</span>
                            <strong>{isZh ? '1-2 周' : '1-2 weeks'}</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 1rem;">
                            <span style="color: var(--text-light);">{t('courses.projects')}</span>
                            <strong>{isZh ? '6 个趣味项目' : '6 fun projects'}</strong>
                        </div>
                        <a href={isZh ? "/zh/tutorials" : "/tutorials"} style="background: #10B981; color: white; padding: 0.5rem 1rem; border-radius: var(--radius); display: block; text-align: center;">{t('courses.cta')}</a>
                    </div>
                </div>
                
                <!-- Intermediate -->
                <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden;">
                    <div style="background: var(--primary); color: white; padding: 1.5rem;">
                        <h3 style="margin-bottom: 0.5rem;">{t('courses.intermediate.title')}</h3>
                        <p style="opacity: 0.9;">{t('courses.intermediate.desc')}</p>
                    </div>
                    <div style="padding: 1.5rem;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);">
                            <span style="color: var(--text-light);">{t('courses.level')}</span>
                            <strong>{isZh ? '中级' : 'Intermediate'}</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);">
                            <span style="color: var(--text-light);">{t('courses.coding')}</span>
                            <strong>{isZh ? '基础 C 语言' : 'Basic C'}</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);">
                            <span style="color: var(--text-light);">{t('courses.duration')}</span>
                            <strong>{isZh ? '1-2 个月' : '1-2 months'}</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 1rem;">
                            <span style="color: var(--text-light);">{t('courses.projects')}</span>
                            <strong>{isZh ? '6 个进阶项目' : '6 advanced projects'}</strong>
                        </div>
                        <a href={isZh ? "/zh/tutorials/intermediate" : "/tutorials/intermediate"} style="background: var(--primary); color: white; padding: 0.5rem 1rem; border-radius: var(--radius); display: block; text-align: center;">{t('courses.cta')}</a>
                    </div>
                </div>
                
                <!-- Advanced -->
                <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden;">
                    <div style="background: #DC2626; color: white; padding: 1.5rem;">
                        <h3 style="margin-bottom: 0.5rem;">{t('courses.advanced.title')}</h3>
                        <p style="opacity: 0.9;">{t('courses.advanced.desc')}</p>
                    </div>
                    <div style="padding: 1.5rem;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);">
                            <span style="color: var(--text-light);">{t('courses.level')}</span>
                            <strong>{isZh ? '高级' : 'Advanced'}</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);">
                            <span style="color: var(--text-light);">{t('courses.coding')}</span>
                            <strong>{isZh ? 'C 语言 + Python' : 'C + Python'}</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);">
                            <span style="color: var(--text-light);">{t('courses.duration')}</span>
                            <strong>{isZh ? '2-3 个月' : '2-3 months'}</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 1rem;">
                            <span style="color: var(--text-light);">{t('courses.projects')}</span>
                            <strong>{isZh ? '7 个挑战项目' : '7 challenge projects'}</strong>
                        </div>
                        <a href={isZh ? "/zh/tutorials/advanced" : "/tutorials/advanced"} style="background: #DC2626; color: white; padding: 0.5rem 1rem; border-radius: var(--radius); display: block; text-align: center;">{t('courses.cta')}</a>
                    </div>
                </div>
            </div>
        </section>
    </main>
    
    <!-- Footer -->
    <footer style="background: var(--primary); color: white; padding: 2rem; margin-top: 4rem;">
        <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem;">
            <!-- Contact -->
            <div>
                <h4 style="margin-bottom: 1rem; font-size: 1.1rem;">{t('footer.contact')}</h4>
                <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                    <a href="https://wa.me/8618601106543" target="_blank" style="color: white; text-decoration: none; display: flex; align-items: center; gap: 0.5rem;">
                        <span>📱</span> {t('footer.whatsapp')}: +86 18601106543
                    </a>
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <span>💬</span> {t('footer.wechat')}: +86 18601106543
                    </div>
                </div>
            </div>
            
            <!-- Social -->
            <div>
                <h4 style="margin-bottom: 1rem; font-size: 1.1rem;">YouTube</h4>
                <a href="https://www.youtube.com/@imagrove" target="_blank" style="color: white; text-decoration: none; display: flex; align-items: center; gap: 0.5rem;">
                    <span>▶️</span> @imagrove
                </a>
            </div>
            
            <!-- Copyright -->
            <div style="display: flex; align-items: flex-end;">
                <p style="font-size: 0.9rem; opacity: 0.8;">{t('footer.copyright')}</p>
            </div>
        </div>
    </footer>
</Layout>
