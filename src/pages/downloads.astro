---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
    title="ESP32 Drone Downloads | Firmware, Code & Apps"
    description="Download ESP32 drone firmware, source code, mobile apps, and documentation. Free drone software for ESP32-S2/S3 flight controller. iOS and Android control apps."
    lang="en"
>
    <Header />
    
    <main style="max-width: 1200px; margin: 0 auto; padding: 2rem;">
        <div style="margin-bottom: 2rem;">
            <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">Downloads</h1>
            <p style="color: var(--text-medium);">Firmware, tools, apps, and documentation for ESP32 Drone</p>
        </div>

        <h2 style="margin: 2rem 0 1rem;">Firmware</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">ESP-Drone Firmware</h4>
                <p style="color: var(--text-medium); margin-bottom: 1rem;">Latest stable firmware for ESP32-S2/S3</p>
                <a href="https://github.com/espressif/esp-drone/releases" target="_blank" style="background: var(--primary); color: white; padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; display: inline-block;">Download</a>
            </div>
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">Bootloader & Partition</h4>
                <p style="color: var(--text-medium); margin-bottom: 1rem;">Required for initial flashing</p>
                <a href="https://docs.espressif.com/projects/espressif-esp-drone/en/latest/gettingstarted.html" target="_blank" style="border: 1px solid var(--border); padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; display: inline-block;">View Docs</a>
            </div>
        </div>

        <h2 style="margin: 2rem 0 1rem;">Mobile Apps</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">iOS App</h4>
                <p style="color: var(--text-medium); margin-bottom: 1rem;">Official ESP-Drone controller for iPhone/iPad</p>
                <a href="https://apps.apple.com/cn/app/esp-drone/id1535623865" target="_blank" style="background: var(--primary); color: white; padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; display: inline-block;">App Store</a>
            </div>
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">Android App</h4>
                <p style="color: var(--text-medium); margin-bottom: 1rem;">Official ESP-Drone controller for Android</p>
                <a href="https://github.com/espressif/esp-drone-android/releases" target="_blank" style="background: var(--primary); color: white; padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; display: inline-block;">Download APK</a>
            </div>
        </div>

        <h2 style="margin: 2rem 0 1rem;">Development Tools</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">ESP-IDF v5.0</h4>
                <p style="color: var(--text-medium); margin-bottom: 1rem;">Official Espressif development framework</p>
                <a href="https://docs.espressif.com/projects/esp-idf/en/v5.0/esp32s2/get-started/index.html" target="_blank" style="border: 1px solid var(--border); padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; display: inline-block;">Get Started</a>
            </div>
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">ESP-Drone Source</h4>
                <p style="color: var(--text-medium); margin-bottom: 1rem;">Complete source code on GitHub</p>
                <a href="https://github.com/espressif/esp-drone" target="_blank" style="border: 1px solid var(--border); padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; display: inline-block;">GitHub</a>
            </div>
        </div>

        <h2 style="margin: 2rem 0 1rem;">Documentation</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">Hardware Schematics</h4>
                <p style="color: var(--text-medium); margin-bottom: 1rem;">PCB design and circuit diagrams</p>
                <a href="https://docs.espressif.com/projects/espressif-esp-drone/en/latest/hardware.html" target="_blank" style="border: 1px solid var(--border); padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; display: inline-block;">View</a>
            </div>
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">3D Print Files</h4>
                <p style="color: var(--text-medium); margin-bottom: 1rem;">Frame STL files for 3D printing</p>
                <a href="https://github.com/espressif/esp-drone/tree/master/docs/_static/3d_files" target="_blank" style="border: 1px solid var(--border); padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; display: inline-block;">Download</a>
            </div>
        </div>

        <div style="background: #DBEAFE; border: 1px solid #93C5FD; border-radius: var(--radius); padding: 1rem; margin-top: 2rem;">
            <strong>Note:</strong> For Chinese documentation and additional resources, visit the <a href="/zh/downloads">Chinese downloads page</a>.
        </div>
    </main>
    
    <Footer />
</Layout>
