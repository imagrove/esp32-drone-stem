---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
    title="ESP32 Drone 下载 | 固件、代码与应用"
    description="下载 ESP32 无人机固件、源代码、手机应用和文档。适用于 ESP32-S2/S3 飞控的免费无人机软件。iOS 和 Android 控制应用。"
    lang="zh"
>
    <Header />
    
    <main style="max-width: 1200px; margin: 0 auto; padding: 2rem;">
        <div style="margin-bottom: 2rem;">
            <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">下载中心</h1>
            <p style="color: var(--text-medium);">ESP32 无人机的固件、工具、应用和文档</p>
        </div>

        <h2 style="margin: 2rem 0 1rem;">固件</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">ESP-Drone 固件</h4>
                <p style="color: var(--text-medium); margin-bottom: 1rem;">适用于 ESP32-S2/S3 的最新稳定版固件</p>
                <a href="https://github.com/espressif/esp-drone/releases" target="_blank" style="background: var(--primary); color: white; padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; display: inline-block;">下载</a>
            </div>
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">引导程序与分区表</h4>
                <p style="color: var(--text-medium); margin-bottom: 1rem;">首次烧录所需</p>
                <a href="https://docs.espressif.com/projects/espressif-esp-drone/en/latest/gettingstarted.html" target="_blank" style="border: 1px solid var(--border); padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; display: inline-block;">查看文档</a>
            </div>
        </div>

        <h2 style="margin: 2rem 0 1rem;">手机应用</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">iOS 应用</h4>
                <p style="color: var(--text-medium); margin-bottom: 1rem;">适用于 iPhone/iPad 的官方 ESP-Drone 控制器</p>
                <a href="https://apps.apple.com/cn/app/esp-drone/id1535623865" target="_blank" style="background: var(--primary); color: white; padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; display: inline-block;">App Store</a>
            </div>
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">Android 应用</h4>
                <p style="color: var(--text-medium); margin-bottom: 1rem;">适用于 Android 的官方 ESP-Drone 控制器</p>
                <a href="https://github.com/espressif/esp-drone-android/releases" target="_blank" style="background: var(--primary); color: white; padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; display: inline-block;">下载 APK</a>
            </div>
        </div>

        <h2 style="margin: 2rem 0 1rem;">开发工具</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">ESP-IDF v5.0</h4>
                <p style="color: var(--text-medium); margin-bottom: 1rem;">乐鑫官方开发框架</p>
                <a href="https://docs.espressif.com/projects/esp-idf/en/v5.0/esp32s2/get-started/index.html" target="_blank" style="border: 1px solid var(--border); padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; display: inline-block;">开始使用</a>
            </div>
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">ESP-Drone 源码</h4>
                <p style="color: var(--text-medium); margin-bottom: 1rem;">GitHub 上的完整源代码</p>
                <a href="https://github.com/espressif/esp-drone" target="_blank" style="border: 1px solid var(--border); padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; display: inline-block;">GitHub</a>
            </div>
        </div>

        <h2 style="margin: 2rem 0 1rem;">文档资料</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">硬件原理图</h4>
                <p style="color: var(--text-medium); margin-bottom: 1rem;">PCB 设计和电路图</p>
                <a href="https://docs.espressif.com/projects/espressif-esp-drone/en/latest/hardware.html" target="_blank" style="border: 1px solid var(--border); padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; display: inline-block;">查看</a>
            </div>
            <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">3D 打印文件</h4>
                <p style="color: var(--text-medium); margin-bottom: 1rem;">机架 STL 文件，用于 3D 打印</p>
                <a href="https://github.com/espressif/esp-drone/tree/master/docs/_static/3d_files" target="_blank" style="border: 1px solid var(--border); padding: 0.5rem 1rem; border-radius: var(--radius); font-size: 0.9rem; display: inline-block;">下载</a>
            </div>
        </div>

        <div style="background: #DBEAFE; border: 1px solid #93C5FD; border-radius: var(--radius); padding: 1rem; margin-top: 2rem;">
            <strong>提示：</strong>英文文档和更多资源请访问 <a href="/downloads">英文下载页面</a>。
        </div>
    </main>

    <Footer />
</Layout>
