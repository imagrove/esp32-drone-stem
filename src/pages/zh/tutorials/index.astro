---
import { getCollection } from 'astro:content';
import TutorialContent from '../../../components/TutorialContent.astro';

// Get first beginner tutorial (Chinese)
const tutorials = await getCollection('tutorials', ({ data }) => {
  return data.draft !== true && data.level === 'beginner' && data.lang === 'zh';
});

tutorials.sort((a, b) => a.data.order - b.data.order);
const firstTutorial = tutorials[0];
---

<TutorialContent entry={firstTutorial} />
