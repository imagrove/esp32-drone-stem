---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header/index.astro';
import Footer from '../../../components/Footer.astro';
---

<Layout
    title="中级教程：飞行工程师 - ESP32 Drone"
    description="ESP32 无人机中级教程。学习代码修改、PID 调参和传感器集成。"
    lang="zh"
>
    <Header />
    
    <main style="max-width: 1200px; margin: 0 auto; padding: 2rem; display: grid; grid-template-columns: 250px 1fr; gap: 2rem;">
        <!-- Sidebar -->
        <aside style="border-right: 1px solid var(--border); padding-right: 1rem;">
            <h3 style="margin-bottom: 1rem; font-size: 0.9rem; text-transform: uppercase; color: var(--text-light);">课程级别</h3>
            <nav style="display: flex; flex-direction: column; gap: 0.5rem;">
                <a href="/zh/tutorials" style="font-size: 0.9rem;">初级：飞行小能手</a>
                <a href="/zh/tutorials/intermediate" style="font-size: 0.9rem; font-weight: 600;">中级：飞行工程师</a>
                <a href="/zh/tutorials/advanced" style="font-size: 0.9rem;">高级：飞行科学家</a>
            </nav>
        </aside>
        
        <!-- Content -->
        <div>
            <div style="margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border);">
                <span style="font-size: 0.85rem; color: #D97706; text-transform: uppercase; font-weight: 600;">中级课程</span>
                <h1 style="margin: 0.5rem 0;">飞行工程师</h1>
                <p style="color: var(--text-medium);">修改代码，理解飞控原理</p>
                <p style="margin-top: 0.5rem; color: var(--text-light); font-size: 0.9rem;">
                    需要基础 C 语言编程知识。<br>
                    学习周期：1-2 个月。
                </p>
            </div>

            <section style="margin-bottom: 2rem;">
                <h2 style="margin-bottom: 1rem;">你将学到什么</h2>
                <ul style="padding-left: 1.5rem;">
                    <li style="margin-bottom: 0.5rem;">使用 ESP-IDF 进行代码修改和编译</li>
                    <li style="margin-bottom: 0.5rem;">PID 控制器调参</li>
                    <li style="margin-bottom: 0.5rem;">传感器数据处理（MPU6050、BMP280）</li>
                    <li style="margin-bottom: 0.5rem;">Wi-Fi 遥测和实时绘图</li>
                    <li style="margin-bottom: 0.5rem;">超声波避障</li>
                </ul>
            </section>

            <section style="margin-bottom: 2rem;">
                <h2 style="margin-bottom: 1rem;">项目列表</h2>
                <div style="display: grid; gap: 1rem;">
                    <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem;">
                        <h4>项目 01：开发环境搭建</h4>
                        <p style="color: var(--text-medium); font-size: 0.9rem;">安装 ESP-IDF，配置开发环境，编译第一个程序</p>
                    </div>
                    <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem;">
                        <h4>项目 02：代码结构解析</h4>
                        <p style="color: var(--text-medium); font-size: 0.9rem;">理解飞控代码架构，学习任务调度</p>
                    </div>
                    <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem;">
                        <h4>项目 03：PID 调参实战</h4>
                        <p style="color: var(--text-medium); font-size: 0.9rem;">理解 PID 控制器，手动调参优化飞行性能</p>
                    </div>
                    <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem;">
                        <h4>项目 04：传感器数据读取</h4>
                        <p style="color: var(--text-medium); font-size: 0.9rem;">读取 MPU6050、BMP280 数据，理解姿态解算</p>
                    </div>
                    <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem;">
                        <h4>项目 05：Wi-Fi 数据回传</h4>
                        <p style="color: var(--text-medium); font-size: 0.9rem;">实现实时数据回传，PC 端数据可视化</p>
                    </div>
                    <div style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem;">
                        <h4>项目 06：超声波避障</h4>
                        <p style="color: var(--text-medium); font-size: 0.9rem;">添加超声波传感器，实现自动避障功能</p>
                    </div>
                </div>
            </section>

            <div style="background: #DBEAFE; border: 1px solid #93C5FD; border-radius: var(--radius); padding: 1rem; margin-top: 2rem;">
                <strong>提示：</strong>中级教程需要完成 <a href="/zh/tutorials">初级教程</a> 或具备同等基础。
            </div>
        </div>
    </main>

    <Footer />
</Layout>
