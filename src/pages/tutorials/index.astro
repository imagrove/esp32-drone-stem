---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const tutorials = await getCollection('tutorials', ({ data }) => {
  return data.draft !== true && data.level === 'beginner';
});

tutorials.sort((a, b) => a.data.order - b.data.order);
---

<Layout 
    title="Drone Tutorials - Learn to Build and Program ESP32 Drones"
    description="Step-by-step drone tutorials from beginner to advanced. Learn drone assembly, programming, flight control, and AI integration."
    lang="en"
>
    <header style="background: white; border-bottom: 1px solid var(--border); padding: 1rem 2rem;">
        <nav style="max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center;">
            <a href="/" style="font-weight: 700; font-size: 1.25rem; color: var(--text-dark);">ESP32 Drone</a>
            <div style="display: flex; gap: 2rem;">
                <a href="/">Home</a>
                <a href="/tutorials" style="font-weight: 600;">Tutorials</a>
                <a href="/hardware">Hardware</a>
                <a href="/downloads">Downloads</a>
            </div>
            <div>
                <a href="/zh/tutorials">中文</a>
            </div>
        </nav>
    </header>
    
    <main style="max-width: 1200px; margin: 0 auto; padding: 2rem;">
        <h1 style="margin-bottom: 2rem;">Tutorials</h1>
        
        <div style="display: grid; gap: 1rem;">
            {tutorials.map((tutorial) => (
                <article style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                    <h2 style="margin-bottom: 0.5rem;">
                        <a href={`/tutorials/${tutorial.slug}`} style="color: var(--text-dark);">
                            {tutorial.data.title}
                        </a>
                    </h2>
                    <p style="color: var(--text-medium); margin-bottom: 1rem;">{tutorial.data.description}</p>
                    <div style="display: flex; gap: 1rem; font-size: 0.85rem; color: var(--text-light);">
                        <span>Level: {tutorial.data.level}</span>
                        <span>Duration: {tutorial.data.duration}</span>
                    </div>
                </article>
            ))}
        </div>
    </main>
</Layout>
