---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header/index.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
    title="Advanced Tutorial: Flight Scientist - ESP32 Drone"
    description="ESP32 Drone advanced tutorial. Algorithm design, AI integration, and autonomous navigation."
    lang="en"
>
    <Header />
    
    <main style="max-width: 1200px; margin: 0 auto; padding: 2rem; display: grid; grid-template-columns: 250px 1fr; gap: 2rem;">
        <!-- Sidebar -->
        <aside style="border-right: 1px solid var(--border); padding-right: 1rem;">
            <h3 style="margin-bottom: 1rem; font-size: 0.9rem; text-transform: uppercase; color: var(--text-light);">Course Levels</h3>
            <nav style="display: flex; flex-direction: column; gap: 0.5rem;">
                <a href="/tutorials" style="font-size: 0.9rem;">Beginner: Flight Explorer</a>
                <a href="/tutorials/intermediate" style="font-size: 0.9rem;">Intermediate: Flight Engineer</a>
                <a href="/tutorials/advanced" style="font-size: 0.9rem; font-weight: 600;">Advanced: Flight Scientist</a>
            </nav>
        </aside>
        
        <!-- Content -->
        <div>
            <div style="margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border);">
                <span style="font-size: 0.85rem; color: #DC2626; text-transform: uppercase; font-weight: 600;">Advanced Level</span>
                <h1 style="margin: 0.5rem 0;">Flight Scientist</h1>
                <p style="color: var(--text-medium);">Algorithm design, system integration, and cutting-edge applications</p>
                <p style="margin-top: 0.5rem; color: var(--text-light); font-size: 0.9rem;">
                    Requires C and Python programming skills.<br>
                    Duration: 2-3 months.
                </p>
            </div>

            <div style="background: #DBEAFE; border: 1px solid #93C5FD; border-radius: var(--radius); padding: 1rem; margin-bottom: 2rem;">
                <strong>Note:</strong> The complete English tutorial is being translated. For full content, please check the <a href="/zh/tutorials/advanced">Chinese version</a>.
            </div>

            <section style="margin-bottom: 2rem;">
                <h2 style="margin-bottom: 1rem;">Challenge Projects</h2>
                <ul style="padding-left: 1.5rem;">
                    <li style="margin-bottom: 0.5rem;">A* Path Planning</li>
                    <li style="margin-bottom: 0.5rem;">Visual-Inertial Odometry (VIO)</li>
                    <li style="margin-bottom: 0.5rem;">Color-based Object Tracking</li>
                    <li style="margin-bottom: 0.5rem;">YOLO AI Object Detection</li>
                    <li style="margin-bottom: 0.5rem;">ESP-NOW MESH Network</li>
                    <li style="margin-bottom: 0.5rem;">Formation Flight</li>
                    <li style="margin-bottom: 0.5rem;">Autonomous Navigation</li>
                </ul>
            </section>

            <section style="text-align: center; margin-top: 2rem;">
                <a href="/zh/tutorials/advanced" style="background: var(--primary); color: white; padding: 0.75rem 1.5rem; border-radius: var(--radius); font-weight: 600;">View Chinese Version</a>
            </section>
        </div>
    </main>

    <Footer />
</Layout>
